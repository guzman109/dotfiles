# Ghostty config — translated from kitty.conf

# --- Font ---
font-family = MonoLisa Variable
font-size = 14
font-thicken = true

# --- Cursor ---
cursor-style-blink = false

# --- Window ---
background-opacity = 0.9
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
window-colorspace = display-p3

# --- Scrollback ---
scrollback-limit = 10000

# --- Shell Integration ---
shell-integration = detect

# --- URLs ---
link-url = true

# --- macOS ---
macos-option-as-alt = true
quit-after-last-window-closed = true
confirm-close-surface = true

# --- Theme: Catppuccin (auto light/dark) ---
# Light: Catppuccin Latte, Dark: Catppuccin Macchiato
# Ghostty automatically switches based on macOS appearance.
theme = light:Catppuccin Latte,dark:Catppuccin Macchiato

# --- Keybindings ---

# Clipboard
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard

# Tabs
keybind = super+t=new_tab
keybind = ctrl+shift+y=new_tab
keybind = super+w=close_surface
keybind = super+shift+w=close_window
keybind = super+shift+right_bracket=next_tab
keybind = super+shift+left_bracket=previous_tab

# Tab switching
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8
keybind = super+9=goto_tab:9

# New OS window
keybind = super+n=new_window

# Font size
keybind = super+equal=increase_font_size:1
keybind = super+shift+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+zero=reset_font_size

# Splits (vsplit = right, hsplit = down)
keybind = super+s=new_split:right
keybind = super+shift+s=new_split:down

# Toggle split zoom (closest to kitty's next_layout)
keybind = super+shift+l=toggle_split_zoom

# Navigate splits (vim-style)
# ctrl+alt: split keyboard | shift+alt: laptop keyboard
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:down
keybind = ctrl+alt+k=goto_split:up
keybind = ctrl+alt+l=goto_split:right
keybind = shift+alt+h=goto_split:left
keybind = shift+alt+j=goto_split:down
keybind = shift+alt+k=goto_split:up
keybind = shift+alt+l=goto_split:right

# Claude Code multi-line prompt support (shift+enter sends ESC+Enter)
keybind = shift+enter=text:\x1b\r
